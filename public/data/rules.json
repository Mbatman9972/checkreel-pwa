{
  "version": "2025.05.1",
  "effective_date": "2025-05-15",
  "last_reviewed": "2025-05-15",
  "platforms": {
    "tiktok": {
      "global": {
        "policy_id": "tiktok_global",
        "rules": {
          "no_nudity": true,
          "no_weapons": true,
          "no_hate_speech": true,
          "no_watermarks": true,
          "no_religious_mockery": true,
          "no_fake_engagement": true,
          "music_limit_seconds": 60,
          "content_originality_required": true
        },
        "content_attributes": {
          "visual": {
            "contains_watermark": false,
            "contains_weapon": false,
            "contains_nudity": false
          },
          "audio": {
            "contains_copyrighted_music": true,
            "music_duration_seconds": 60
          },
          "metadata": {
            "commercial_intent": true,
            "political_content": true
          },
          "context_flags": {
            "is_educational": true,
            "is_documentary": false
          },
          "platform_specific": {
            "uses_trending_sound": true,
            "shows_challenges": true
          }
        },
        "version": "2025.05.1"
      },
      "regional_exceptions": {
        "MENA": {
          "additional_restrictions": [
            "no_religious_music",
            "no_public_dancing",
            "modesty_required"
          ]
        },
        "EU": {
          "gdpr_compliance_required": true,
          "political_content_reviewed": true
        },
        "US": {
          "coppa_compliance": true
        }
      }
    }
  }
}
