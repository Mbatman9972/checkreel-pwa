{
  "platforms": {
    "tiktok": {
      "version": "2025.05.1",
      "global": {
        "content_attributes": {
          "visual": {
            "contains_watermark": false,
            "contains_weapon": false,
            "contains_nudity": false,
            "contains_violence": false
          },
          "audio": {
            "contains_copyrighted_music": false,
            "contains_explicit_language": false
          },
          "metadata": {
            "commercial_intent": false,
            "political_content": false
          }
        }
      },
      "regional_exceptions": {
        "MENA": {
          "additional_restrictions": [
            "no_religious_music",
            "no_public_dancing",
            "modesty_required"
          ]
        },
        "EU": {
          "gdpr_compliance_required": true,
          "political_content_reviewed": true
        },
        "US": {
          "coppa_compliance": true
        }
      }
    }
  }
}
